<% content_for :title, "All Movies" %>

<h1>All Movies</h1>

<%= form_with url: movies_path, method: :get, local: true, id: "ratings_form" do %>
  Include:
  <% @all_ratings.each do |rating| %>
    <%= label_tag "ratings_#{rating}", rating %>
    <%= check_box_tag "ratings[#{rating}]", "1", @selected_ratings.include?(rating), id: "ratings_#{rating}" %>
  <% end %>
  <%= hidden_field_tag :sort_by, @sort_by if @sort_by.present? %>
  <%= submit_tag "Refresh", id: "ratings_submit" %>
<% end %>

<table id="movies">
  <thead>
    <tr>
      <th class="<%= 'hilite' if @sort_by == 'title' %>">
        <%= link_to 'Movie Title', movies_path(sort_by: 'title', ratings: @ratings_hash), id: :title_header %>
      </th>
      <th>Rating</th>
      <th class="<%= 'hilite' if @sort_by == 'release_date' %>">
        <%= link_to 'Release Date', movies_path(sort_by: 'release_date', ratings: @ratings_hash), id: :release_date_header %>
      </th>
      <th>More Info</th>
      <th>Edit</th>
      <th>Delete</th>
    </tr>
  </thead>
  <tbody>
    <% @movies.each do |movie| %>
      <tr>
        <td><%= movie.title %></td>
        <td><%= movie.rating %></td>
        <td><%= movie.release_date %></td>
        <td><%= link_to "More about #{movie.title}", movie_path(movie) %></td>
        <td><%= link_to "Edit", edit_movie_path(movie) %></td>
        <td>
          <%= link_to "Delete", movie_path(movie), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "Add New Movie", new_movie_path %>
